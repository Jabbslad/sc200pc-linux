# Fork of the Arch 'libcamera' package with the SC200PC sensor helper +
# CameraSensorProperties entry patched in so the simple soft IPA can run
# a correct AGC/AWB on the Samsung SC200PC (ACPI SSLC2000).
#
# Tracking Arch's libcamera PKGBUILD — bump _arch_pkgver/_arch_pkgrel and
# rebase the patches when Arch pushes a new libcamera version.

pkgbase=libcamera-sc200pc
pkgname=(
  libcamera-sc200pc
  libcamera-sc200pc-ipa
  libcamera-sc200pc-tools
  gst-plugin-libcamera-sc200pc
)
options=(!debug)
_upstream_pkgver=0.7.0
pkgver=0.7.0
pkgrel=2
pkgdesc="libcamera with the Samsung SC200PC sensor helper baked in"
arch=(x86_64)
url="https://github.com/jabbslad/sc200pc-linux"
_url=https://git.libcamera.org/libcamera/libcamera.git
makedepends=(
  cmake
  git
  glib2
  gst-plugins-base
  gtest
  libdrm
  libjpeg-turbo
  libtiff
  libyaml
  libyuv
  meson
  qt6-base
  qt6-tools
  sdl2
  systemd
)
source=(
  "git+$_url#tag=v$_upstream_pkgver"
  "libcamera-fix-python3.14-macro-redefinition.patch"
  "libcamera-sc200pc.patch"
  "sc200pc.yaml"
  "sc200pc-libcamera-check"
)
sha512sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')
b2sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

_pick() {
  local p="$1" f d; shift
  for f; do
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -p "$(dirname "$d")"
    mv "$f" "$d"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "$f")"
  done
}

prepare() {
  cd libcamera
  patch -Np1 < ../libcamera-fix-python3.14-macro-redefinition.patch
  patch -Np1 < ../libcamera-sc200pc.patch
  printf "%s\n" "$_upstream_pkgver" > .tarball-version
}

build() {
  local meson_options=(
    -D v4l2=enabled
    -D tracing=disabled
    -D test=true
    -D documentation=disabled
    -D pycamera=disabled
  )

  arch-meson libcamera build "${meson_options[@]}"
  meson compile -C build
}

check() {
  local tests=$(
    meson test -C build --list | awk '{print $3}' \
      | grep -v single_stream_test \
      | grep -v multi_stream_test \
      | grep -v memory_lifetime_test \
  )
  # shellcheck disable=SC2068
  meson test -C build ${tests[@]}
}

package_libcamera-sc200pc() {
  pkgdesc+=" - core library"
  license=(
    Apache-2.0
    CC0-1.0
    'GPL-2.0-only WITH Linux-syscall-note'
    GPL-2.0-or-later
    LGPL-2.1-or-later
    'GPL-2.0-or-later WITH Linux-syscall-note OR BSD-3-Clause'
    'GPL-2.0-or-later WITH Linux-syscall-note OR MIT'
  )
  depends=(
    glibc
    gnutls
    libcamera-sc200pc-ipa
    libelf
    libgcc
    libglvnd
    libstdc++
    libunwind
    libyaml
    libyuv
    sh
    systemd-libs libudev.so
  )
  optdepends=(
    'gst-plugin-libcamera-sc200pc: GStreamer plugin'
    'libcamera-sc200pc-tools: applications (cam, qcam, lc-compliance)'
  )
  provides=(libcamera libcamera.so libcamera-base.so)
  conflicts=(libcamera)
  replaces=(libcamera)

  meson install -C build --destdir "$pkgdir"
  install -vDm 644 libcamera/LICENSES/{BSD-3-Clause,Linux-syscall-note,MIT}.txt \
    -t "$pkgdir/usr/share/licenses/$pkgname/"

  # Bundled SC200PC assets.
  install -vDm 644 "$srcdir/sc200pc.yaml" \
    "$pkgdir/usr/share/libcamera/ipa/simple/sc200pc.yaml"
  install -vDm 755 "$srcdir/sc200pc-libcamera-check" \
    "$pkgdir/usr/bin/sc200pc-libcamera-check"

  (
    cd "$pkgdir"
    _pick libcamera-sc200pc-ipa   usr/lib/libcamera/
    _pick libcamera-sc200pc-tools usr/bin/{cam,qcam,lc-compliance}
    _pick gst-plugin-libcamera-sc200pc usr/lib/gstreamer-*
  )
}

package_libcamera-sc200pc-ipa() {
  pkgdesc+=" - signed IPA (with SC200PC helper)"
  license=(
    BSD-2-Clause
    CC-BY-SA-4.0
    CC0-1.0
    GPL-2.0-or-later
    LGPL-2.1-or-later
  )
  depends=(
    glibc
    libcamera-sc200pc libcamera.so libcamera-base.so
    libgcc
    libstdc++
  )
  provides=(libcamera-ipa)
  conflicts=(libcamera-ipa)
  replaces=(libcamera-ipa)
  # stripping re-signs IPA libs; do it manually.
  options=(!strip)

  strip "$pkgname"/usr/lib/libcamera/*{.so,proxy}
  for _lib in "$pkgname"/usr/lib/libcamera/*.so; do
    libcamera/src/ipa/ipa-sign.sh \
      "$(find build -type f -iname '*ipa-priv-key.pem')" "$_lib" "$_lib.sign"
  done
  mv -v "$pkgname"/* "$pkgdir"
  install -vDm 644 libcamera/LICENSES/BSD-2-Clause.txt \
    -t "$pkgdir/usr/share/licenses/$pkgname/"
}

package_libcamera-sc200pc-tools() {
  pkgdesc+=" - tools (cam, qcam, lc-compliance)"
  license=(
    BSD-2-Clause
    CC0-1.0
    GPL-2.0-or-later
    LGPL-2.1-or-later
  )
  depends=(
    glibc
    gtest
    libcamera-sc200pc libcamera.so libcamera-base.so
    libdrm
    libevent libevent-2.1.so libevent_pthreads-2.1.so
    libgcc
    libjpeg-turbo libjpeg.so
    libstdc++
    libtiff libtiff.so
    libyaml
    qt6-base
    sdl2
  )
  provides=(libcamera-tools)
  conflicts=(libcamera-tools)
  replaces=(libcamera-tools)

  mv -v "$pkgname"/* "$pkgdir"
  install -vDm 644 libcamera/LICENSES/BSD-2-Clause.txt \
    -t "$pkgdir/usr/share/licenses/$pkgname/"
}

package_gst-plugin-libcamera-sc200pc() {
  pkgdesc="GStreamer plugin for libcamera (with SC200PC helper)"
  license=(
    CC0-1.0
    LGPL-2.1-or-later
  )
  depends=(
    glib2 libg{lib,object}-2.0.so
    glibc
    gst-plugins-base-libs
    gstreamer
    libcamera-sc200pc libcamera.so libcamera-base.so
    libgcc
    libstdc++
  )
  provides=(gst-plugin-libcamera)
  conflicts=(gst-plugin-libcamera)
  replaces=(gst-plugin-libcamera)

  mv -v "$pkgname"/* "$pkgdir"
}

