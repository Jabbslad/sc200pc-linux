# Restore user-session access to the raw IPU7 capture node for the
# SC200PC native libcamera path.
#
# intel-ipu7-camera ships /usr/lib/udev/rules.d/71-ipu7-hide-isys.rules,
# which intentionally hides "Intel IPU7 ISYS Capture *" nodes behind
# root:root 0600 because the vendor HAL path expects applications to use
# the v4l2-relayd loopback device instead. That breaks the native
# libcamera/PipeWire path, which needs direct access to /dev/video0.
#
# Run this after 71-ipu7-hide-isys.rules but before 73-seat-late.rules so
# the active-seat ACL is re-applied normally.
SUBSYSTEM=="video4linux", ATTR{name}=="Intel IPU7 ISYS Capture *", TAG+="uaccess", TAG+="seat", MODE="0660", GROUP="video"
