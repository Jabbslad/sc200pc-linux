pkgname=sc200pc-dkms
pkgver=0.5.3
pkgrel=1
pkgdesc="Samsung/SmartSens SC200PC (SSLC2000) V4L2 sensor driver — DKMS"
arch=('any')
url="https://github.com/jabbslad/sc200pc-linux"
license=('GPL-2.0-only')
depends=('dkms')
source=(
  'README.md'
  'dkms.conf'
  'Kbuild'
  'Makefile'
  'sc200pc.c'
)
sha256sums=(
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
)

package() {
  local srcdir_pkg="/usr/src/${pkgname%-dkms}-${pkgver}"

  install -d "${pkgdir}${srcdir_pkg}"
  install -m644 README.md "${pkgdir}${srcdir_pkg}/README.md"
  install -m644 dkms.conf "${pkgdir}${srcdir_pkg}/dkms.conf"
  install -m644 Kbuild "${pkgdir}${srcdir_pkg}/Kbuild"
  install -m644 Makefile "${pkgdir}${srcdir_pkg}/Makefile"
  install -m644 sc200pc.c "${pkgdir}${srcdir_pkg}/sc200pc.c"
}
